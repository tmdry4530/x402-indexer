NODE_ENV=development
PORT=3000

# Infrastructure
DATABASE_URL=postgres://postgres:postgres@localhost:5432/x402_indexer
REDIS_URL=redis://localhost:6379
# Public Base RPC works for light smoke tests, but backfills can hit rate limits.
# Prefer a dedicated provider (for example Chainstack) for sustained indexing.
BASE_RPC_URL=https://mainnet.base.org
# Optional comma-separated fallback RPCs. Useful for pairing a public smoke-test RPC
# with one or more dedicated providers in production.
BASE_RPC_FALLBACK_URLS=
BASE_RPC_TIMEOUT_MS=30000
BASE_RPC_RETRY_COUNT=5
BASE_RPC_RETRY_DELAY_MS=500

# Pipeline
FINALITY_LAG=10
MAX_REORG_DEPTH=20
BACKFILL_CHUNK_SIZE=100
CONFIDENCE_THRESHOLD=70
FACILITATOR_FILTER_MODE=soft

# Known registries (comma-separated addresses)
# Base USDC
KNOWN_ASSETS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
# Optional manual overrides. Leave blank to rely on facilitator source sync below.
KNOWN_FACILITATORS=
KNOWN_PROXIES=

# External metadata
DEFI_LLAMA_BASE_URL=https://coins.llama.fi
OPENCHAIN_BASE_URL=https://api.openchain.xyz
FACILITATOR_SOURCE_ENABLED=true
FACILITATOR_SOURCE_URL=https://facilitators.x402.watch/
FACILITATOR_SOURCE_NETWORK=base

# Runtime switches
ENABLE_REALTIME_WORKER=false
ENABLE_BACKFILL_WORKER=false
AUTO_MIGRATE=true
