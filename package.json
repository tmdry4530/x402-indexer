{
  "name": "x402-indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "trace:indexing": "node scripts/capture-indexing-trace.mjs",
    "trace:workflow": "node scripts/capture-indexing-workflow.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "bullmq": "^5.75.2",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "viem": "^2.48.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "pg-mem": "^3.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
